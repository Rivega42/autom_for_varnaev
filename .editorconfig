# Единый стиль файлов (CLAUDE.md §2: UTF-8, LF).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# В Markdown хвостовые пробелы значимы (жёсткий перенос строки) — не трогаем.
[*.md]
trim_trailing_whitespace = false

[*.py]
indent_size = 4
