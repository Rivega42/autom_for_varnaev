# go2rtc — медиа-шлюз камер. ПРИМЕР конфига (без реальных адресов и паролей).
#
# Реальный конфиг: скопируйте файл в go2rtc.yaml РЯДОМ (cp go2rtc.yaml.example
# go2rtc.yaml) и впишите адреса/логины/пароли камер объекта. go2rtc.yaml — в
# .gitignore: RTSP-URL содержат пароли камер, в репозиторий они не попадают
# (CLAUDE.md §5).
#
# Имя потока (ключ в streams) ДОЛЖНО совпадать с именем камеры в справочнике
# cameras: по нему GUI берёт кадр-превью, а воркер аналитики — ретранслятор
# rtsp://media-gateway:8554/<имя-потока>.
#
# Второй источник «ffmpeg:<имя>#video=mjpeg» — MJPEG-транскод для живого
# просмотра в браузере (GUI); основной H.264-поток он не трогает.

api:
  listen: ":1984"

streams:
  cam-01:
    - rtsp://LOGIN:PASSWORD@192.168.1.50:554/1/1
    - ffmpeg:cam-01#video=mjpeg
  cam-02:
    - rtsp://LOGIN:PASSWORD@192.168.1.51:554/1/1
    - ffmpeg:cam-02#video=mjpeg
