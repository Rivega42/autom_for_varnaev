<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_event_flow"
                  targetNamespace="http://monitoring/spec">

  <bpmn:process id="Proc_EventFlow" name="Поток события в единый журнал" isExecutable="false">
    <bpmn:startEvent id="Start" name="Источник: датчик или аналитика">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="G_Src" name="Откуда событие?">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F_Sens</bpmn:outgoing>
      <bpmn:outgoing>F_An</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="T_Sensor" name="ingest-sensors: показание сверено с порогом">
      <bpmn:incoming>F_Sens</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Analytics" name="video-analytics: артефакт-скриншот сохранён на том">
      <bpmn:incoming>F_An</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="T_Send" name="Отправка события в log-service (внутр. REST)">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Validate" name="log-service: валидация типа события">
      <bpmn:incoming>F4</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Persist" name="Запись в таблицу events (+ ссылка на артефакт)">
      <bpmn:incoming>F5</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End" name="Событие доступно: Grafana, GET /events, АУРА (v2)">
      <bpmn:incoming>F6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="G_Src"/>
    <bpmn:sequenceFlow id="F_Sens" name="датчик" sourceRef="G_Src" targetRef="T_Sensor"/>
    <bpmn:sequenceFlow id="F_An" name="аналитика" sourceRef="G_Src" targetRef="T_Analytics"/>
    <bpmn:sequenceFlow id="F2" sourceRef="T_Sensor" targetRef="T_Send"/>
    <bpmn:sequenceFlow id="F3" sourceRef="T_Analytics" targetRef="T_Send"/>
    <bpmn:sequenceFlow id="F4" sourceRef="T_Send" targetRef="T_Validate"/>
    <bpmn:sequenceFlow id="F5" sourceRef="T_Validate" targetRef="T_Persist"/>
    <bpmn:sequenceFlow id="F6" sourceRef="T_Persist" targetRef="End"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="Diag_EF">
    <bpmndi:BPMNPlane id="Plane_EF" bpmnElement="Proc_EventFlow">
      <bpmndi:BPMNShape id="S_Start" bpmnElement="Start">
        <dc:Bounds x="120" y="240" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="100" y="280" width="80" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GSrc" bpmnElement="G_Src" isMarkerVisible="true">
        <dc:Bounds x="210" y="233" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="196" y="203" width="80" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Sensor" bpmnElement="T_Sensor">
        <dc:Bounds x="320" y="140" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Analytics" bpmnElement="T_Analytics">
        <dc:Bounds x="320" y="300" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Send" bpmnElement="T_Send">
        <dc:Bounds x="560" y="218" width="170" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Validate" bpmnElement="T_Validate">
        <dc:Bounds x="780" y="218" width="160" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Persist" bpmnElement="T_Persist">
        <dc:Bounds x="990" y="218" width="180" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_End" bpmnElement="End">
        <dc:Bounds x="1220" y="240" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1196" y="280" width="90" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="E_F1" bpmnElement="F1"><di:waypoint x="156" y="258"/><di:waypoint x="210" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_FSens" bpmnElement="F_Sens"><di:waypoint x="235" y="233"/><di:waypoint x="235" y="180"/><di:waypoint x="320" y="180"/>
        <bpmndi:BPMNLabel><dc:Bounds x="244" y="195" width="44" height="20"/></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_FAn" bpmnElement="F_An"><di:waypoint x="235" y="283"/><di:waypoint x="235" y="340"/><di:waypoint x="320" y="340"/>
        <bpmndi:BPMNLabel><dc:Bounds x="242" y="318" width="60" height="20"/></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F2" bpmnElement="F2"><di:waypoint x="500" y="180"/><di:waypoint x="645" y="180"/><di:waypoint x="645" y="218"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F3" bpmnElement="F3"><di:waypoint x="500" y="340"/><di:waypoint x="645" y="340"/><di:waypoint x="645" y="298"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F4" bpmnElement="F4"><di:waypoint x="730" y="258"/><di:waypoint x="780" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F5" bpmnElement="F5"><di:waypoint x="940" y="258"/><di:waypoint x="990" y="258"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F6" bpmnElement="F6"><di:waypoint x="1170" y="258"/><di:waypoint x="1220" y="258"/></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
