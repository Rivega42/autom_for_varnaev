<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_task_lifecycle"
                  targetNamespace="http://monitoring/spec">

  <bpmn:process id="Proc_TaskLifecycle" name="Жизненный цикл задания на анализ" isExecutable="false">
    <bpmn:startEvent id="Start" name="Триггер: расписание (v1) или АУРА (v2)">
      <bpmn:outgoing>F1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="T_Queued" name="queued: задание создано">
      <bpmn:incoming>F1</bpmn:incoming>
      <bpmn:outgoing>F2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G_Cancel" name="Отменено до запуска?">
      <bpmn:incoming>F2</bpmn:incoming>
      <bpmn:outgoing>F_Yes</bpmn:outgoing>
      <bpmn:outgoing>F_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Running" name="running: аналитика идёт">
      <bpmn:incoming>F_No</bpmn:incoming>
      <bpmn:outgoing>F3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="G_Result" name="Успех?">
      <bpmn:incoming>F3</bpmn:incoming>
      <bpmn:outgoing>F_Ok</bpmn:outgoing>
      <bpmn:outgoing>F_Err</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="T_Done" name="done: события и артефакты записаны">
      <bpmn:incoming>F_Ok</bpmn:incoming>
      <bpmn:outgoing>F4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Failed" name="failed: ошибка зафиксирована">
      <bpmn:incoming>F_Err</bpmn:incoming>
      <bpmn:outgoing>F5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="T_Cancelled" name="cancelled">
      <bpmn:incoming>F_Yes</bpmn:incoming>
      <bpmn:outgoing>F6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Ok" name="Готово">
      <bpmn:incoming>F4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Err" name="Завершено с ошибкой">
      <bpmn:incoming>F5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Cancel" name="Отменено">
      <bpmn:incoming>F6</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="T_Queued"/>
    <bpmn:sequenceFlow id="F2" sourceRef="T_Queued" targetRef="G_Cancel"/>
    <bpmn:sequenceFlow id="F_Yes" name="да" sourceRef="G_Cancel" targetRef="T_Cancelled"/>
    <bpmn:sequenceFlow id="F_No" name="нет" sourceRef="G_Cancel" targetRef="T_Running"/>
    <bpmn:sequenceFlow id="F3" sourceRef="T_Running" targetRef="G_Result"/>
    <bpmn:sequenceFlow id="F_Ok" name="да" sourceRef="G_Result" targetRef="T_Done"/>
    <bpmn:sequenceFlow id="F_Err" name="нет" sourceRef="G_Result" targetRef="T_Failed"/>
    <bpmn:sequenceFlow id="F4" sourceRef="T_Done" targetRef="End_Ok"/>
    <bpmn:sequenceFlow id="F5" sourceRef="T_Failed" targetRef="End_Err"/>
    <bpmn:sequenceFlow id="F6" sourceRef="T_Cancelled" targetRef="End_Cancel"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="Diag_TL">
    <bpmndi:BPMNPlane id="Plane_TL" bpmnElement="Proc_TaskLifecycle">
      <bpmndi:BPMNShape id="S_Start" bpmnElement="Start">
        <dc:Bounds x="120" y="200" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="96" y="240" width="86" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Queued" bpmnElement="T_Queued">
        <dc:Bounds x="210" y="178" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GCancel" bpmnElement="G_Cancel" isMarkerVisible="true">
        <dc:Bounds x="400" y="193" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="384" y="160" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Running" bpmnElement="T_Running">
        <dc:Bounds x="500" y="178" width="140" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GResult" bpmnElement="G_Result" isMarkerVisible="true">
        <dc:Bounds x="690" y="193" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="697" y="160" width="40" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Done" bpmnElement="T_Done">
        <dc:Bounds x="790" y="178" width="150" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Failed" bpmnElement="T_Failed">
        <dc:Bounds x="790" y="320" width="150" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Cancelled" bpmnElement="T_Cancelled">
        <dc:Bounds x="400" y="320" width="120" height="70"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndOk" bpmnElement="End_Ok">
        <dc:Bounds x="990" y="200" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="982" y="240" width="54" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndErr" bpmnElement="End_Err">
        <dc:Bounds x="990" y="337" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="966" y="377" width="84" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_EndCancel" bpmnElement="End_Cancel">
        <dc:Bounds x="442" y="430" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="424" y="470" width="72" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="E_F1" bpmnElement="F1"><di:waypoint x="156" y="218"/><di:waypoint x="210" y="218"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F2" bpmnElement="F2"><di:waypoint x="350" y="218"/><di:waypoint x="400" y="218"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_FNo" bpmnElement="F_No"><di:waypoint x="450" y="218"/><di:waypoint x="500" y="218"/>
        <bpmndi:BPMNLabel><dc:Bounds x="463" y="200" width="24" height="20"/></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_FYes" bpmnElement="F_Yes"><di:waypoint x="425" y="243"/><di:waypoint x="425" y="320"/>
        <bpmndi:BPMNLabel><dc:Bounds x="432" y="270" width="24" height="20"/></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F3" bpmnElement="F3"><di:waypoint x="640" y="218"/><di:waypoint x="690" y="218"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_FOk" bpmnElement="F_Ok"><di:waypoint x="740" y="218"/><di:waypoint x="790" y="218"/>
        <bpmndi:BPMNLabel><dc:Bounds x="753" y="200" width="24" height="20"/></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_FErr" bpmnElement="F_Err"><di:waypoint x="715" y="243"/><di:waypoint x="715" y="355"/><di:waypoint x="790" y="355"/>
        <bpmndi:BPMNLabel><dc:Bounds x="722" y="290" width="24" height="20"/></bpmndi:BPMNLabel></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F4" bpmnElement="F4"><di:waypoint x="940" y="218"/><di:waypoint x="990" y="218"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F5" bpmnElement="F5"><di:waypoint x="940" y="355"/><di:waypoint x="990" y="355"/></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_F6" bpmnElement="F6"><di:waypoint x="460" y="390"/><di:waypoint x="460" y="430"/></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
