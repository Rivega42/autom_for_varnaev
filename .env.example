# ─────────────────────────────────────────────────────────────────────────────
# Пример переменных окружения контура мониторинга.
# Скопируй в .env и заполни значения. Реальные секреты в репозиторий не кладём
# (CLAUDE.md §5): .env в .gitignore, здесь — только безопасные плейсхолдеры.
# ─────────────────────────────────────────────────────────────────────────────

# --- База данных (TimescaleDB = PostgreSQL 16 + расширение timescaledb) ---
POSTGRES_HOST=db                 # имя сервиса БД во внутренней сети Docker
POSTGRES_PORT=5432
POSTGRES_DB=monitoring
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=change-me      # ЗАМЕНИ в .env
# Пользователь только для чтения (Grafana) — см. provisioning datasource
POSTGRES_RO_USER=grafana_ro
POSTGRES_RO_PASSWORD=change-me
# Политики хранения сырых показаний (#295; применяет сервис migrate):
READINGS_COMPRESS_AFTER_DAYS=7   # сжимать чанки sensor_readings старше N дней (lossless)
READINGS_RETENTION_DAYS=0        # удалять сырьё старше N дней; 0 = выключено (значения по #41)

# --- Брокер датчиков (Mosquitto, MQTT) ---
MQTT_HOST=mqtt-broker
MQTT_PORT=1883
MQTT_USERNAME=                   # пусто = анонимно (только во внутренней сети)
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=monitoring     # префикс топиков показаний от ESPHome-узлов
SENSOR_SILENT_MIN=10             # узел молчит дольше N мин → событие sensor_silent

# --- Медиа-шлюз камер (go2rtc) ---
GO2RTC_API_PORT=1984             # API/WebRTC превью (наружу не публикуем в v1)
GO2RTC_URL=http://media-gateway:1984  # api-gateway тянет кадр-превью для GUI разметки ROI

# --- Общий том артефактов (скриншоты сейчас, видео в v2) ---
ARTIFACTS_DIR=/data/artifacts    # путь внутри контейнеров к общему тому
ARTIFACTS_RETENTION_DAYS=30      # ротация скриншотов: старше N дней удаляются (0 = выключено)

# --- Внутренний журнал событий (log-service) ---
# Адрес лог-сервиса во внутренней сети — пишут ingest-sensors и video-analytics,
# проксирует api-gateway. Наружу не публикуется.
LOG_SERVICE_URL=http://log-service:8000

# --- api-gateway (единственный внешний REST-вход) ---
API_BASE_PREFIX=/api/v1
API_KEY=change-me                # значение заголовка X-API-Key для публичных и /integration/*
# Роли (#291): ключи per-user «ключ:роль» через запятую (роли operator|admin).
# operator — чтение и подтверждение событий (ack); admin — ещё и настройка
# (камеры/пороги/расписания/правила/справочники). API_KEY выше = роль admin.
# Если и API_KEY, и API_KEYS пусты — проверка ключа отключена (только dev/тесты).
API_KEYS=                        # пример: operatorKey:operator,adminKey:admin
# Лицензия (#335): пусто = демо-тариф (1 помещение / 1 камера / 1 узел). Ключ
# (Ed25519-подписанный, см. docs/14_LICENSING.md) снимает/расширяет лимит.
LICENSE_KEY=

# --- Планировщик заданий (scheduler) ---
SCHEDULER_CONFIG=/config/schedules.json  # файл расписаний (см. config/README.md)
SCHEDULER_TICK_S=60                       # период тика планировщика, сек
CAMERA_PROBE_TIMEOUT_S=8                  # таймаут пробы живости камеры, сек (#331): короткий → ложные camera_offline
SERVICE_SILENT_MIN=5                      # watchdog (#284): порог «тишины» heartbeat сервиса, мин
PRESENCE_TZ=UTC                           # часовой пояс окон контроля присутствия (#300), IANA-имя

# --- Видеоаналитика ---
ANALYTICS_FPS=5                  # понижение fps для анализа (5–8 достаточно на CPU)
# Лимит кадров на один прогон анализа live-потока (RTSP бесконечен). ~150 кадров
# при 5 fps ≈ 30 c окна; затем считается покрытие зон и задание завершается.
ANALYTICS_MAX_STREAM_FRAMES=150
# Контроль спецодежды (#272): нарушение, если «белого халата» нет дольше N секунд.
ANALYTICS_UNIFORM_MIN_S=5
# Бинарный ассет модели MediaPipe PoseLandmarker (положить в ./models, см. models/README.md)
ANALYTICS_MODEL_PATH=/models/pose_landmarker.task

# --- Grafana (дашборды) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

# --- Журналирование ---
LOG_LEVEL=INFO                   # сообщения оператору — на русском (CLAUDE.md §2)

# --- Уведомления о событиях (#264; канал включается заданием его переменных) ---
NOTIFY_MIN_SEVERITY=warning      # info|warning|critical — порог отправки
NOTIFY_TYPES=                    # CSV типов событий (пусто = любой тип)
TELEGRAM_BOT_TOKEN=              # токен бота (BotFather); пусто = Telegram выключен
TELEGRAM_CHAT_ID=                # id чата/группы для оповещений
NOTIFY_WEBHOOK_URL=              # generic webhook (POST JSON) на каждое событие
SMTP_HOST=                       # SMTP-сервер; пусто = e-mail выключен
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true
NOTIFY_EMAIL_FROM=               # отправитель
NOTIFY_EMAIL_TO=                 # получатели (CSV)
NOTIFY_ESCALATE_AFTER_MIN=0      # эскалация: повтор, если событие не подтверждено за N мин (0 = выкл)
NOTIFY_ESCALATE_REPEAT_MIN=30    # пауза между повторами, мин
NOTIFY_ESCALATE_MAX=3            # максимум повторов на событие
NOTIFY_ESCALATE_SEVERITIES=critical  # важности для эскалации (CSV)

# --- Резервное копирование БД (#267; сервис backup) ---
BACKUP_KEEP=14          # сколько последних дампов хранить (<=0 — ротация выкл.)
BACKUP_INTERVAL_H=24    # период между бэкапами, часов (минимум 1)

# --- СТЫК-АУРА (v2): интеграция выключена в v1 ---
AURA_INTEGRATION_ENABLED=false   # true включает разъёмы /integration/* (только v2)
