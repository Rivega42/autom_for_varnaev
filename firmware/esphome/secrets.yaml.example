# Пример секретов узла датчиков (ESPHome).
# Скопируйте этот файл рядом как secrets.yaml и подставьте реальные значения:
#   cp secrets.yaml.example secrets.yaml
# secrets.yaml В РЕПОЗИТОРИЙ НЕ КОММИТИТСЯ (CLAUDE.md §5) — он в .gitignore.
# Конфиги узлов (node.example.yaml, cold_chamber.example.yaml) берут эти значения
# через !secret.

# Wi-Fi сети объекта, в которой находится сервер с MQTT-брокером.
wifi_ssid: "ИМЯ_WIFI"
wifi_password: "ПАРОЛЬ_WIFI"

# Пароль для обновления прошивки по воздуху (OTA).
ota_password: "ПАРОЛЬ_OTA"

# Адрес MQTT-брокера = IP сервера объекта (контейнер mqtt-broker слушает 1883).
mqtt_broker: "192.168.0.10"

# Если на брокере включена авторизация (mqtt/mosquitto.conf), раскомментируйте
# и задайте; в node.example.yaml тогда добавьте username/password в блок mqtt:.
# mqtt_username: "node"
# mqtt_password: "ПАРОЛЬ_MQTT"
