{
  "uid": "events-log",
  "title": "Журнал событий",
  "tags": ["мониторинг", "события"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_TIMESCALEDB",
        "type": "datasource",
        "query": "postgres",
        "current": { "text": "TimescaleDB", "value": "TimescaleDB" },
        "hide": 0
      },
      {
        "name": "room",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
        "definition": "SELECT DISTINCT room_id FROM events ORDER BY 1",
        "query": "SELECT DISTINCT room_id FROM events ORDER BY 1",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "type",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
        "definition": "SELECT DISTINCT type FROM events ORDER BY 1",
        "query": "SELECT DISTINCT type FROM events ORDER BY 1",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "severity",
        "type": "custom",
        "query": "info,warning,critical",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Лента событий",
      "type": "table",
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "options": { "showHeader": true },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ts AS \"time\", source, type, room_id AS room, severity, message FROM events WHERE room_id IN (${room:singlequote}) AND type IN (${type:singlequote}) AND severity IN (${severity:singlequote}) AND $__timeFilter(ts) ORDER BY ts DESC LIMIT 500"
        }
      ]
    }
  ]
}
